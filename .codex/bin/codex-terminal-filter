#!/usr/bin/env python3
import errno
import fcntl
import os
import pty
import re
import select
import shutil
import signal
import struct
import sys
import termios
import time
import tty


CURSOR_SHAPE_RE = re.compile(rb"(?:\x1b\[|\x9b)[0-9]* q")
MAX_CURSOR_SHAPE_LEN = 12
CAPTURE_OUTPUT = False
CAPTURE_OUTPUT_PATH = "/private/tmp/codex-filter.log"
FORCE_CURSOR_SHAPE = True
FORCED_CURSOR_SHAPE = b"\x1b[6 q"  # DECSCUSR: steady vertical bar


class OutputFilter:
    def __init__(self):
        self.pending = b""

    def feed(self, data, final=False):
        data = self._rewrite(self.pending + data)
        if final:
            self.pending = b""
            return data

        keep = self._pending_prefix_len(data)
        if keep == 0:
            self.pending = b""
            return data

        self.pending = data[-keep:]
        return data[:-keep]

    def _rewrite(self, data):
        if FORCE_CURSOR_SHAPE:
            return CURSOR_SHAPE_RE.sub(FORCED_CURSOR_SHAPE, data)
        return CURSOR_SHAPE_RE.sub(b"", data)

    def _pending_prefix_len(self, data):
        max_keep = min(MAX_CURSOR_SHAPE_LEN, len(data))
        for keep in range(max_keep, 0, -1):
            if self._is_cursor_shape_prefix(data[-keep:]):
                return keep
        return 0

    def _is_cursor_shape_prefix(self, data):
        if data == b"\x1b":
            return True
        if data.startswith(b"\x1b["):
            params = data[2:]
        elif data.startswith(b"\x9b"):
            params = data[1:]
        else:
            return False

        if params == b"":
            return True
        if params.endswith(b" "):
            params = params[:-1]
            return params == b"" or params.isdigit()
        return params.isdigit()


def get_winsize(fd):
    try:
        packed = fcntl.ioctl(fd, termios.TIOCGWINSZ, b"\0" * 8)
        return struct.unpack("HHHH", packed)
    except OSError:
        return None


def set_winsize(fd, size):
    if size is None:
        return
    try:
        fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack("HHHH", *size))
    except OSError:
        pass


def set_nonblocking(fd):
    flags = fcntl.fcntl(fd, fcntl.F_GETFL)
    fcntl.fcntl(fd, fcntl.F_SETFL, flags | os.O_NONBLOCK)


def write_all(fd, data):
    while data:
        try:
            written = os.write(fd, data)
            data = data[written:]
        except BlockingIOError:
            select.select([], [fd], [])


def child_status_to_exit_code(status):
    if os.WIFEXITED(status):
        return os.WEXITSTATUS(status)
    if os.WIFSIGNALED(status):
        return 128 + os.WTERMSIG(status)
    return 1


def open_capture_log():
    if CAPTURE_OUTPUT:
        return open(CAPTURE_OUTPUT_PATH, "ab", buffering=0)

    path = os.environ.get("CODEX_TERMINAL_FILTER_LOG")
    if not path:
        return None
    return open(os.path.abspath(os.path.expanduser(path)), "ab", buffering=0)


def log_output(log_file, data):
    if log_file is None or not data:
        return
    timestamp = time.strftime("%Y-%m-%d %H:%M:%S")
    log_file.write(f"\n[{timestamp}] {len(data)} bytes\n".encode())
    log_file.write(repr(data).encode())
    log_file.write(b"\n")


def main():
    target = os.environ.get("CODEX_TERMINAL_FILTER_TARGET", "codex")
    target_path = shutil.which(target)
    if target_path is None:
        print(f"{target}: command not found", file=sys.stderr)
        return 127

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()
    original_attrs = None
    original_flags = None
    capture_log = open_capture_log()
    if os.isatty(stdin_fd):
        original_attrs = termios.tcgetattr(stdin_fd)
        tty.setraw(stdin_fd)

    pid, master_fd = pty.fork()
    if pid == 0:
        os.execvp(target_path, [target, *sys.argv[1:]])

    set_winsize(master_fd, get_winsize(stdin_fd))
    original_flags = fcntl.fcntl(stdin_fd, fcntl.F_GETFL)
    set_nonblocking(stdin_fd)
    set_nonblocking(master_fd)

    resize_pending = False
    child_status = None
    output_filter = OutputFilter()

    def request_resize(_signum, _frame):
        nonlocal resize_pending
        resize_pending = True

    def forward_signal(signum, _frame):
        try:
            os.kill(pid, signum)
        except ProcessLookupError:
            pass

    signal.signal(signal.SIGWINCH, request_resize)
    for signum in (signal.SIGHUP, signal.SIGTERM):
        signal.signal(signum, forward_signal)

    try:
        stdin_open = True
        while True:
            if resize_pending:
                resize_pending = False
                set_winsize(master_fd, get_winsize(stdin_fd))

            if child_status is None:
                try:
                    waited, status = os.waitpid(pid, os.WNOHANG)
                    if waited == pid:
                        child_status = status
                except ChildProcessError:
                    child_status = 0

            read_fds = [master_fd]
            if child_status is None and stdin_open:
                read_fds.append(stdin_fd)

            try:
                readable, _, _ = select.select(read_fds, [], [], 0.1)
            except OSError as err:
                if err.errno == errno.EINTR:
                    continue
                raise

            if stdin_fd in readable:
                try:
                    data = os.read(stdin_fd, 65536)
                except BlockingIOError:
                    data = b""
                if data:
                    write_all(master_fd, data)
                else:
                    stdin_open = False
                    write_all(master_fd, b"\x04")

            if master_fd in readable:
                try:
                    data = os.read(master_fd, 65536)
                except OSError as err:
                    if err.errno == errno.EIO:
                        data = b""
                    else:
                        raise

                if data:
                    log_output(capture_log, data)
                    write_all(stdout_fd, output_filter.feed(data))
                else:
                    final = output_filter.feed(b"", final=True)
                    if final:
                        write_all(stdout_fd, final)
                    break

            if child_status is not None and not readable:
                break
    finally:
        if original_flags is not None:
            fcntl.fcntl(stdin_fd, fcntl.F_SETFL, original_flags)
        if original_attrs is not None:
            termios.tcsetattr(stdin_fd, termios.TCSADRAIN, original_attrs)
        try:
            os.close(master_fd)
        except OSError:
            pass
        if capture_log is not None:
            capture_log.close()

    if child_status is None:
        try:
            _, child_status = os.waitpid(pid, 0)
        except ChildProcessError:
            child_status = 0

    return child_status_to_exit_code(child_status)


if __name__ == "__main__":
    sys.exit(main())
